pico-8 cartridge // http://www.pico-8.com
version 42
__lua__

-- test infrastructure
testmode = false
test_log = {}
test_inputs = {}
test_input_idx = 0

function _log(msg)
  if testmode then add(test_log, msg) end
end

function test_input(b)
  if testmode and test_input_idx < #test_inputs then
    test_input_idx += 1
    return test_inputs[test_input_idx] or 0
  end
  return btn()
end

-- game state
state = "menu"
score = 0
lives = 3
level = 1
frame_time = 0
difficulty = 1

-- ball
ball = {x=64, y=100, vx=0, vy=0, r=3}

-- obstacles
obstacles = {}
spawn_timer = 0
spawn_interval = 60

-- particles
particles = {}

function _init()
  _log("state:menu")
end

function reset_game()
  ball = {x=64, y=100, vx=0, vy=0, r=3}
  obstacles = {}
  particles = {}
  score = 0
  lives = 3
  level = 1
  frame_time = 0
  difficulty = 1
  spawn_timer = 0
  spawn_interval = 60
  _log("state:play")
end

function update_menu()
  if test_input(4) > 0 then  -- o button
    reset_game()
    state = "play"
  end
end

function draw_menu()
  cls(1)
  print("dodge game", 50, 40, 7)
  print("press o to start", 40, 60, 7)
  print("score: "..score, 50, 80, 7)
end

function update_ball()
  ball.vy += 0.2  -- gravity
  ball.x += ball.vx
  ball.y += ball.vy

  -- friction
  ball.vx *= 0.95

  -- boundaries
  if ball.x < ball.r then
    ball.x = ball.r
    ball.vx = -ball.vx * 0.5
  end
  if ball.x > 128 - ball.r then
    ball.x = 128 - ball.r
    ball.vx = -ball.vx * 0.5
  end
  if ball.y < ball.r then
    ball.y = ball.r
    ball.vy = -ball.vy * 0.5
  end
  if ball.y > 128 - ball.r then
    -- fell off bottom
    lives -= 1
    _log("life_lost")
    _log("lives:"..lives)
    ball.y = 100
    ball.vy = 0
  end
end

function spawn_obstacle()
  local x = 20 + rnd(88)
  local y = -10
  local vx = (rnd() - 0.5) * 2
  local vy = 1 + rnd(1)
  add(obstacles, {x=x, y=y, vx=vx, vy=vy, r=4, type=rnd(3) > 1 and "spike" or "box"})
end

function update_obstacles()
  spawn_timer += 1
  if spawn_timer >= spawn_interval then
    spawn_timer = 0
    spawn_obstacle()
    spawn_interval = max(20, spawn_interval - level)
  end

  for o in all(obstacles) do
    o.x += o.vx
    o.y += o.vy
    o.vy += 0.15

    -- collision with ball
    local dist = sqrt((ball.x - o.x)^2 + (ball.y - o.y)^2)
    if dist < ball.r + o.r then
      lives -= 1
      _log("hit_obstacle")
      _log("lives:"..lives)
      del(obstacles, o)
    end

    if o.y > 128 then
      score += 10 * level
      del(obstacles, o)
    end
  end
end

function update_play()
  local input = test_input()

  if input & 1 > 0 then ball.vx -= 0.8 end  -- left
  if input & 2 > 0 then ball.vx += 0.8 end  -- right
  if input & 4 > 0 then ball.vy = -3 end    -- up (jump)

  update_ball()
  update_obstacles()

  frame_time += 1
  if frame_time % 300 == 0 then
    level += 1
    _log("level:"..level)
  end

  if lives <= 0 then
    state = "gameover"
    _log("state:gameover")
  end

  if test_input(32) > 0 then  -- x button, cheat for testing
    state = "gameover"
  end
end

function draw_play()
  cls(1)

  -- ball
  circfill(ball.x, ball.y, ball.r, 10)

  -- obstacles
  for o in all(obstacles) do
    if o.type == "spike" then
      circfill(o.x, o.y, o.r, 8)
    else
      rectfill(o.x-o.r, o.y-o.r, o.x+o.r, o.y+o.r, 8)
    end
  end

  -- ui
  print("score:"..score, 5, 5, 7)
  print("lives:"..lives, 5, 15, 7)
  print("level:"..level, 5, 25, 7)
end

function update_gameover()
  if test_input(4) > 0 then  -- o button
    state = "menu"
    _log("state:menu")
  end
end

function draw_gameover()
  cls(1)
  print("game over", 50, 40, 8)
  print("final score: "..score, 38, 60, 7)
  print("press o for menu", 35, 80, 7)
end

function _update()
  if state == "menu" then
    update_menu()
  elseif state == "play" then
    update_play()
  elseif state == "gameover" then
    update_gameover()
  end
end

function _draw()
  if state == "menu" then
    draw_menu()
  elseif state == "play" then
    draw_play()
  elseif state == "gameover" then
    draw_gameover()
  end
end


pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
-- Rhythm Blast
-- Match button presses to a beat pattern

-- test infrastructure
testmode = false
test_log = {}
test_inputs = {}
test_input_idx = 0

function _log(msg)
  if testmode then add(test_log, msg) end
end

function test_input(b)
  if testmode and test_input_idx < #test_inputs then
    test_input_idx += 1
    return test_inputs[test_input_idx] or 0
  end
  return btn()
end

-- game state
state = "menu"
score = 0
health = 3
level = 1
current_beat = 0
beat_tempo = 30
beat_counter = 0

-- rhythm pattern (o_button=16, x_button=32)
rhythm_pattern = {16, 32, 16, 32, 16, 16, 32, 32}
pattern_index = 1
pattern_complete = false

-- combo tracker
combo = 0
max_combo = 0

-- input detection
last_input = 0

function _update()
  if state == "menu" then update_menu()
  elseif state == "play" then update_play()
  elseif state == "gameover" then update_gameover()
  end
end

function _draw()
  cls(1)
  if state == "menu" then draw_menu()
  elseif state == "play" then draw_play()
  elseif state == "gameover" then draw_gameover()
  end
end

function update_menu()
  if test_input(4) > 0 or test_input(5) > 0 then  -- o or x button
    _log("state:play")
    state = "play"
    score = 0
    health = 3
    level = 1
    pattern_index = 1
    combo = 0
    max_combo = 0
    beat_counter = 0
  end
end

function draw_menu()
  print("rhythm blast", 40, 20, 7)
  print("press o or x to start", 25, 50, 11)
  print("match the beat!", 35, 65, 12)
  print("score: " .. score, 40, 100, 6)
end

function update_play()
  beat_counter += 1
  if beat_counter >= beat_tempo then
    beat_counter = 0
    current_beat += 1
    _log("beat:" .. current_beat)

    if current_beat > 8 then
      if pattern_complete then
        _log("level_complete")
        level += 1
        pattern_index = 1
        current_beat = 0
        beat_tempo = max(10, beat_tempo - 2)
        pattern_complete = false
      end
    end
  end

  local input = test_input(4) + test_input(5)

  if input > 0 and last_input == 0 then
    local expected = rhythm_pattern[pattern_index]
    if input == expected then
      _log("hit")
      score += 10 * level
      combo += 1
      if combo > max_combo then max_combo = combo end
      pattern_index += 1

      if pattern_index > #rhythm_pattern then
        pattern_complete = true
        _log("pattern_complete")
      end
    else
      _log("miss")
      health -= 1
      combo = 0
      if health <= 0 then
        _log("gameover:lose")
        state = "gameover"
      end
    end
  end

  last_input = input
end

function draw_play()
  -- header
  print("level " .. level, 5, 5, 7)
  print("score:" .. score, 50, 5, 6)
  print("hp:" .. health, 100, 5, 8)

  -- beat display
  local beat_x = 20 + (current_beat % 8) * 12
  circfill(beat_x, 20, 3, 12)

  -- pattern indicator
  print("next:", 5, 35, 7)
  local next_btn = rhythm_pattern[pattern_index]
  if next_btn == 16 then
    print("o", 35, 35, 10)
  else
    print("x", 35, 35, 9)
  end

  -- combo display
  print("combo:" .. combo, 5, 50, 11)

  -- progress bar
  local progress = (pattern_index - 1) / #rhythm_pattern
  rectfill(20, 65, 20 + 88 * progress, 71, 11)
  rect(20, 65, 108, 71, 7)

  -- button layout
  print("o", 40, 85, 10)
  print("x", 70, 85, 9)

  -- show current input
  local input = test_input(4) + test_input(5)
  if input == 16 then
    circfill(44, 100, 6, 10)
  elseif input == 32 then
    rectfill(66, 94, 82, 110, 9)
  end
end

function update_gameover()
  if test_input(4) > 0 or test_input(5) > 0 then
    _log("state:menu")
    state = "menu"
  end
end

function draw_gameover()
  print("game over!", 40, 30, 8)
  print("final score: " .. score, 30, 50, 6)
  print("max combo: " .. max_combo, 35, 65, 11)
  print("levels cleared: " .. level, 30, 80, 7)
  print("press o or x to menu", 20, 105, 12)
end

__gfx__

pico-8 cartridge // http://www.pico-8.com
version 41
__lua__
-- Tile Match Puzzle Game
-- 2026-03-06

testmode=false
test_log={}
test_inputs={}
test_input_idx=0

function _log(msg)
 if testmode then add(test_log,msg) end
end

function _capture()
 if testmode then add(test_log,"SCREEN:"..tostr(stat(0))) end
end

function test_input(b)
 if testmode and test_input_idx<#test_inputs then
  test_input_idx+=1
  return test_inputs[test_input_idx] or 0
 end
 return btn()
end

-- Game state
state="menu"
score=0
grid={}
cols=4
rows=4
tile_size=24
grid_x=20
grid_y=32
target_score=100
sel_x=0
sel_y=0
matched={}
fall_queue={}

function _init()
 _log("state:init")
 init_grid()
end

function init_grid()
 grid={}
 for y=1,rows do
  grid[y]={}
  for x=1,cols do
   grid[y][x]=flr(rnd(6))+1
  end
 end
 matched={}
 sel_x=0
 sel_y=0
end

function _update()
 if state=="menu" then update_menu()
 elseif state=="play" then update_play()
 elseif state=="gameover" then update_gameover()
 end
end

function _draw()
 cls()
 if state=="menu" then draw_menu()
 elseif state=="play" then draw_play()
 elseif state=="gameover" then draw_gameover()
 end
end

function update_menu()
 if test_input(4)>0 or btnp(4) then
  _log("state:play")
  state="play"
  score=0
  init_grid()
 end
end

function draw_menu()
 print("tile match",48,20,7)
 print("match 3+ tiles",34,35,7)
 print("reach 100 pts",40,45,7)
 print("press z to start",32,65,7)
end

function update_play()
 if test_input(0)>0 or btnp(0) then
  sel_x=max(0,sel_x-1)
 end
 if test_input(1)>0 or btnp(1) then
  sel_x=min(cols-1,sel_x+1)
 end
 if test_input(2)>0 or btnp(2) then
  sel_y=max(0,sel_y-1)
 end
 if test_input(3)>0 or btnp(3) then
  sel_y=min(rows-1,sel_y+1)
 end

 if test_input(4)>0 or btnp(4) then
  match_tiles()
 end

 if #fall_queue>0 then
  apply_fall()
 end

 if score>=target_score then
  _log("gameover:win")
  state="gameover"
 end

 if is_grid_stuck() then
  _log("gameover:lose")
  state="gameover"
 end
end

function match_tiles()
 local color=grid[sel_y+1][sel_x+1]
 matched={}

 find_matches(sel_x+1,sel_y+1,color)

 if #matched>=3 then
  _log("match:"..#matched)
  score+=#matched*10
  remove_matched()
 end
end

function find_matches(x,y,color)
 if x<1 or x>cols or y<1 or y>rows then return end
 if grid[y][x]!=color then return end

 for i=1,#matched do
  if matched[i][1]==x and matched[i][2]==y then
   return
  end
 end

 add(matched,{x,y})
 find_matches(x+1,y,color)
 find_matches(x-1,y,color)
 find_matches(x,y+1,color)
 find_matches(x,y-1,color)
end

function remove_matched()
 for i=1,#matched do
  local x=matched[i][1]
  local y=matched[i][2]
  grid[y][x]=0
 end
 apply_gravity()
end

function apply_gravity()
 for x=1,cols do
  for y=rows,2,-1 do
   if grid[y][x]==0 then
    local found=false
    for yy=y-1,1,-1 do
     if grid[yy][x]>0 then
      grid[y][x]=grid[yy][x]
      grid[yy][x]=0
      found=true
      break
     end
    end
    if not found then
     grid[y][x]=flr(rnd(6))+1
    end
   end
  end
 end
end

function apply_fall()
 fall_queue={}
end

function is_grid_stuck()
 for y=1,rows do
  for x=1,cols do
   if grid[y][x]==0 then
    return true
   end
  end
 end
 return false
end

function update_gameover()
 if test_input(4)>0 or btnp(4) then
  _log("state:menu")
  state="menu"
 end
end

function draw_play()
 print("score:"..score,6,6,7)
 print("target:100",6,14,7)

 for y=1,rows do
  for x=1,cols do
   local px=grid_x+(x-1)*tile_size+4
   local py=grid_y+(y-1)*tile_size+4
   local col=grid[y][x]

   if sel_x==x-1 and sel_y==y-1 then
    rectfill(px-6,py-6,px+10,py+10,7)
   end

   if col>0 then
    circfill(px,py,6,col)
   else
    pset(px,py,5)
   end
  end
 end
end

function draw_gameover()
 if score>=target_score then
  print("you win!",48,50,10)
  print("score:"..score,44,60,7)
 else
  print("game over",44,50,8)
  print("score:"..score,44,60,7)
 end
 print("press z",46,75,7)
end


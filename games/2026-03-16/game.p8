pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
-- Slide Puzzle - Solve a 4x4 sliding tile puzzle
-- test infrastructure
testmode = false
test_log = {}
test_inputs = {}
test_input_idx = 0

function _log(msg)
  if testmode then add(test_log, msg) end
end

function _capture()
  if testmode then add(test_log, "SCREEN:"..tostr(stat(0))) end
end

function test_input(b)
  if testmode and test_input_idx < #test_inputs then
    test_input_idx += 1
    return test_inputs[test_input_idx] or 0
  end
  return btn()
end

-- game state
state = "menu"
grid = {}
empty_x, empty_y = 4, 4
moves = 0
time_start = 0

-- init
function init_game()
  _log("state:play")
  -- create solved puzzle
  local num = 1
  for y = 1, 4 do
    for x = 1, 4 do
      grid[y * 4 + x] = num
      num += 1
    end
  end
  grid[16] = 0 -- empty space
  empty_x, empty_y = 4, 4
  moves = 0

  -- shuffle: do 100 random moves
  for i = 1, 100 do
    local moves_list = {}
    if empty_x > 1 then add(moves_list, {-1, 0}) end
    if empty_x < 4 then add(moves_list, {1, 0}) end
    if empty_y > 1 then add(moves_list, {0, -1}) end
    if empty_y < 4 then add(moves_list, {0, 1}) end

    local move = moves_list[1 + flr(rnd(#moves_list))]
    local nx, ny = empty_x + move[1], empty_y + move[2]
    swap_tile(nx, ny)
  end

  moves = 0
  time_start = t()
  _log("game:init")
end

function swap_tile(x, y)
  if x < 1 or x > 4 or y < 1 or y > 4 then return end
  local i1 = y * 4 + x
  local i2 = empty_y * 4 + empty_x
  grid[i1], grid[i2] = grid[i2], grid[i1]
  empty_x, empty_y = x, y
end

function is_solved()
  local num = 1
  for y = 1, 4 do
    for x = 1, 4 do
      local idx = y * 4 + x
      if y == 4 and x == 4 then
        if grid[idx] ~= 0 then return false end
      else
        if grid[idx] ~= num then return false end
      end
      num += 1
    end
  end
  return true
end

function _update()
  if state == "menu" then
    if test_input(4) > 0 or btnp(4) then
      init_game()
      state = "play"
    end
  elseif state == "play" then
    -- handle tile swaps
    if btnp(0) then -- left
      swap_tile(empty_x + 1, empty_y)
      moves += 1
      _log("move:"..moves)
    end
    if btnp(1) then -- right
      swap_tile(empty_x - 1, empty_y)
      moves += 1
      _log("move:"..moves)
    end
    if btnp(2) then -- up
      swap_tile(empty_x, empty_y + 1)
      moves += 1
      _log("move:"..moves)
    end
    if btnp(3) then -- down
      swap_tile(empty_x, empty_y - 1)
      moves += 1
      _log("move:"..moves)
    end

    if is_solved() then
      _log("gameover:win")
      state = "gameover"
    end
  elseif state == "gameover" then
    if test_input(4) > 0 or btnp(4) then
      state = "menu"
      _log("state:menu")
    end
  end
end

function _draw()
  cls(1)

  if state == "menu" then
    draw_menu()
  elseif state == "play" then
    draw_play()
  elseif state == "gameover" then
    draw_gameover()
  end
end

function draw_menu()
  print("slide puzzle", 40, 20, 7)
  print("solve the", 44, 35, 7)
  print("4x4 puzzle", 40, 42, 7)
  print("", 0, 55, 0)
  print("press z to play", 32, 70, 7)
end

function draw_play()
  -- draw grid
  local tile_size = 24
  local x_offset = 16
  local y_offset = 16

  for y = 1, 4 do
    for x = 1, 4 do
      local idx = y * 4 + x
      local val = grid[idx]
      local px = x_offset + (x - 1) * tile_size
      local py = y_offset + (y - 1) * tile_size

      if val == 0 then
        rectfill(px, py, px + 22, py + 22, 1)
      else
        rectfill(px, py, px + 22, py + 22, 3)
        rect(px, py, px + 22, py + 22, 7)
        print(val, px + 9, py + 8, 0)
      end
    end
  end

  -- info
  print("moves: "..moves, 10, 112, 7)
end

function draw_gameover()
  print("puzzle solved!", 32, 30, 7)
  print("moves: "..moves, 44, 50, 7)
  print("", 0, 65, 0)
  print("press z for menu", 32, 80, 7)
end


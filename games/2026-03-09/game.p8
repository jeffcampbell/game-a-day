pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
-- Star Blaster
-- Destroy enemy ships to score points. Don't let them reach the bottom!

-- test infrastructure
testmode=false
test_log={}
test_inputs={}
test_input_idx=0

function _log(msg)
	if testmode then add(test_log,msg) end
end

function _capture()
	if testmode then add(test_log,"SCREEN:"..tostr(stat(0))) end
end

function test_input(b)
	if testmode and test_input_idx<#test_inputs then
		test_input_idx+=1
		return test_inputs[test_input_idx] or 0
	end
	return btn()
end

-- globals
state="menu"
player_x=64
player_y=115
score=0
health=3
wave=1
enemies={}
bullets={}
spawn_timer=0
spawn_interval=70

function _init()
	_log("game:init")
end

function _update()
	if state=="menu" then update_menu()
	elseif state=="play" then update_play()
	elseif state=="gameover" then update_gameover()
	end
end

function _draw()
	cls()
	if state=="menu" then draw_menu()
	elseif state=="play" then draw_play()
	elseif state=="gameover" then draw_gameover()
	end
end

-- menu
function update_menu()
	if test_input(4) > 0 then  -- O button
		_log("state:play")
		state="play"
	end
end

function draw_menu()
	print("star blaster",40,30,7)
	print("destroy enemies to score",24,50,5)
	print("avoid getting hit!",28,60,5)
	print("",64,80,0)
	print("arrow keys to move",20,80,7)
	print("z/c to shoot",28,90,7)
	print("press z/c to start",24,110,11)
end

-- play
function update_play()
	-- player movement
	if test_input(0) > 0 then  -- left
		player_x=max(4,player_x-2)
	end
	if test_input(1) > 0 then  -- right
		player_x=min(124,player_x+2)
	end

	-- shooting
	if test_input(4) > 0 then  -- O button
		add(bullets,{x=player_x,y=player_y-8})
	end

	-- update bullets
	for i=#bullets,1,-1 do
		local b=bullets[i]
		b.y-=4
		if b.y<0 then
			deli(bullets,i)
		end
	end

	-- spawn enemies
	spawn_timer+=1
	if spawn_timer>=spawn_interval then
		spawn_timer=0
		local ex=rnd(128)
		add(enemies,{x=ex,y=0,alive=true})
	end

	-- update enemies
	for i=#enemies,1,-1 do
		local e=enemies[i]
		e.y+=1

		-- collision with player
		if e.alive and abs(e.x-player_x)<8 and abs(e.y-player_y)<8 then
			e.alive=false
			health-=1
			_log("health:"..health)
			if health<=0 then
				_log("gameover:lose")
				state="gameover"
			end
		end

		-- remove if off screen
		if e.y>128 then
			if e.alive then
				deli(enemies,i)
			end
		end
	end

	-- bullet-enemy collisions
	for bi=#bullets,1,-1 do
		local b=bullets[bi]
		for ei=#enemies,1,-1 do
			local e=enemies[ei]
			if e.alive and abs(b.x-e.x)<8 and abs(b.y-e.y)<8 then
				e.alive=false
				deli(bullets,bi)
				score+=1
				_log("score:"..score)
				break
			end
		end
	end

	-- clean up dead enemies
	for i=#enemies,1,-1 do
		if not enemies[i].alive then
			deli(enemies,i)
		end
	end

	-- win condition
	if score>=10 then
		_log("gameover:win")
		state="gameover"
	end
end

function draw_play()
	-- background
	for x=0,128,8 do
		for y=0,128,8 do
			if (x+y)%16==0 then
				print(".",x,y,1)
			end
		end
	end

	-- player ship
	spr(1,player_x-4,player_y-4)

	-- bullets
	for b in all(bullets) do
		rectfill(b.x-1,b.y-2,b.x+1,b.y,11)
	end

	-- enemies
	for e in all(enemies) do
		if e.alive then
			spr(2,e.x-4,e.y-4)
		end
	end

	-- hud
	print("enemies:"..score.."/10",4,4,7)
	print("health:"..health,4,12,8)
end

-- gameover
function update_gameover()
	if test_input(4) > 0 then  -- O button
		-- reset
		state="menu"
		player_x=64
		player_y=115
		score=0
		health=3
		wave=1
		enemies={}
		bullets={}
		spawn_timer=0
		_log("state:menu")
	end
end

function draw_gameover()
	if score>=10 then
		print("victory!",48,40,11)
		print("final score:"..score,32,60,7)
	else
		print("game over",44,40,8)
		print("score:"..score,48,60,7)
	end
	print("press z/c to continue",20,100,5)
end

